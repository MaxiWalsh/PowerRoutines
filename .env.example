APP_NAME=PowerRoutines
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://powerroutines-api.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Obtené los datos en: supabase.com → tu proyecto → Settings → Database
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=tu_password_de_supabase

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.onrender.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel
FRONTEND_URL=https://powerroutines.vercel.app

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Credenciales en: mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# ── Mail (opcional por ahora) ─────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@powerroutines.app"
MAIL_FROM_NAME="${APP_NAME}"
